{
  "expo": {
    "name": "AssistMe",
    "slug": "assistme",
    "owner": "atif-adnan-asst",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "assistme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atifadnanasst.assistme"
    },
    "android": {
      "package": "com.atifadnanasst.assistme",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#121218"
      },
      "permissions": ["android.permission.READ_CONTACTS"],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "resizeMode": "cover",
          "backgroundColor": "#0D2B23"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-contacts"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "06cec730-38f8-462b-96e3-a7f29fb9b804"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/06cec730-38f8-462b-96e3-a7f29fb9b804"
    }
  }
}
